<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <div class="auth-popup-container" style="position: fixed; z-index: 3000; top: 0; left: 0; width: 100%; height: 100%;">
                            <div class="auth-modal">
                                <div class="welcome-icon">🔒</div>
                                <h2 class="fw-bold">Access Denied</h2>
                                <p>You do not have the necessary permissions to view this page. Please contact your administrator if you believe this is an error.</p>
                                
                                <div class="app-stats mb-3">
                                    <div class="stat-item">
                                        <span class="stat-value">403</span>
                                        <span class="stat-label">Forbidden</span>
                                    </div>
                                    <div class="stat-divider"></div>
                                    <div class="stat-item">
                                        <span class="stat-value">Private</span>
                                        <span class="stat-label">Area</span>
                                    </div>
                                </div>

                                <button class="auth-action-btn" onclick="window.location.href='/'">Return to Safety</button>
                            </div>
                        </div>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>
