@page "/map"
@using MyTransportAppWASM.Services.Interfaces
@using MyTransportAppWASM.Models.Transport
@using MyTransportAppWASM.Services

<link href="css/map.css" rel="stylesheet"/>

<div id="map-container" class="@(Theme.IsDarkMode ? "theme-dark" : "theme-light")">
    <div id="map"></div>

    <div class="map-overlay @(isCollapsed ? "collapsed" : "")">
        <div class="overlay-header" @onclick="ToggleCollapse">
            @if (isCollapsed)
            {
                <span class="collapsed-icon">📍</span>
            }
            else
            {
                <h2>📍 Rapid Bus Tracker</h2>
                <span class="collapse-icon">Collapse -</span>
            }
        </div>

        @if (!isCollapsed)
        {
            <div class="overlay-body">
                <div class="control-group mb-3">
                    <label class="standard-label">Origin</label>
                    <div id="origin-input" class="standard-input autocomplete-container"></div>
                </div>

                <div class="control-group mb-3">
                    <label class="standard-label">Destination</label>
                    <div id="destination-input" class="standard-input autocomplete-container"></div>
                </div>

                <div class="control-group mb-3">
                    <label class="standard-label">Travel Mode</label>
                    <select @bind="mode" class="standard-input">
                        <option value="TRANSIT">🚌 Transit</option>
                        <option value="WALKING">🚶 Walking</option>
                        <option value="DRIVING">🚗 Driving</option>
                        <option value="BICYCLING">🚲 Bicycling</option>
                    </select>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button @onclick="ShowRoute" class="standard-button standard-button-primary flex-grow-1">
                        🗺️ Route
                    </button>
                    <button @onclick="ClearRoute" class="standard-button bg-light text-dark flex-grow-1" style="font-size: 0.85rem;">
                        🗑️ Clear
                    </button>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button @onclick="() => RequestManualLocationUpdate()" class="standard-button bg-light text-dark flex-grow-1" style="font-size: 0.85rem;">
                        🎯 My Location
                    </button>
                    <button @onclick="RefreshBusPosition" class="standard-button bg-light text-dark flex-grow-1" style="font-size: 0.85rem;">
                        🔄 Update Buses
                    </button>
                </div>

                <div class="tracker-status">
                    <span class="pulse-dot"></span>
                    <span>@(string.IsNullOrEmpty(locationStatus) ? "Ready" : locationStatus)</span>
                </div>
            </div>
        }
    </div>
</div>

