@using MyTransportAppWASM.Services.Interfaces
@inject IGeocodingService GeocodingService
@inject IJSRuntime JSRuntime
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config
@implements IDisposable
@implements IAsyncDisposable

<div class="d-flex gap-2 align-items-start w-100">
    <div class="position-relative flex-grow-1">
    <input class="form-input w-100" 
           id="@Id"
           @bind="_searchText" 
           @bind:event="oninput" 
           @bind:after="TriggerSearch"
           @onkeyup="HandleKeyUp" 
           @onkeydown="HandleKeyDown"
           role="combobox"
           aria-expanded="@(_showSuggestions ? "true" : "false")"
           aria-controls="autocomplete-listbox"
           aria-autocomplete="list"
           aria-activedescendant="@(_activeIndex >= 0 && _suggestions.Count > _activeIndex ? $"suggestion-{_activeIndex}" : null)"
           placeholder="e.g., Kuala Lumpur Sentral" />

    @if (_showSuggestions)
    {
        <div class="position-absolute w-100 mt-1 p-0 shadow-sm"
             style="z-index: 1000; max-height: 250px; overflow-y: auto; background: var(--bg-color, #fff); border-radius: 12px; border: 1px solid var(--border-color); overflow-x: hidden;">
            <ul id="autocomplete-listbox" class="list-unstyled m-0" role="listbox">
                @if (_isSearchingSuggestions && _suggestions.Count == 0)
                {
                    <li class="p-2 text-muted" role="option" aria-disabled="true">Searching...</li>
                }
                else if (!_isSearchingSuggestions && _suggestions.Count == 0)
                {
                    <li class="p-2 text-muted" role="option" aria-disabled="true">No results found.</li>
                }
                else
                {
                    @for (int i = 0; i < _suggestions.Count; i++)
                    {
                        var suggestion = _suggestions[i];
                        int currentIndex = i;
                        bool isActive = currentIndex == _activeIndex;
                        
                        <li id="suggestion-@currentIndex"
                            class="p-2 border-bottom @(isActive ? "bg-light text-primary" : "")" 
                            style="cursor: pointer;" 
                            role="option" 
                            aria-selected="@(isActive ? "true" : "false")"
                            @onclick="() => SelectSuggestion(suggestion)"
                            @onmouseover="() => _activeIndex = currentIndex">
                            <strong>@suggestion.Name</strong><br />
                            <small class="@(isActive ? "text-primary opacity-75" : "text-dim")">@suggestion.FormattedAddress</small>
                        </li>
                    }
                }
            </ul>
        </div>
    }
    </div>
    
    <button type="button" class="btn btn-outline-primary" @onclick="OpenMapModal" title="Select on Map">
        <i class="bi bi-map"></i>
    </button>
</div>

<dialog id="location-picker-modal" @ref="_mapDialog" aria-labelledby="map-modal-title" style="width: 90vw; height: 80vh; max-width: 800px; max-height: 600px; padding: 0; border: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">
    <div class="d-flex flex-column h-100 position-relative">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center" style="background: var(--bg-color, #fff); z-index: 2;">
            <h5 id="map-modal-title" class="m-0" style="color: var(--text-color, #000);">Select a Location</h5>
            <form method="dialog">
                <button class="btn-close" aria-label="Close" @onclick="CloseMapModal"></button>
            </form>
        </div>
        
        <!-- JS Managed Island -->
        <div class="flex-grow-1" style="min-height: 300px; width: 100%; z-index: 1;">
            <div id="picker-map-container" style="width: 100%; height: 100%;"></div>
        </div>
        
        <!-- Blazor Managed Overlay -->
        <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 1000; pointer-events: none;">
            @if (_isLoadingMap)
            {
               <div class="position-absolute top-50 start-50 translate-middle">
                  <div class="spinner-border text-primary" role="status">
                      <span class="visually-hidden">Loading...</span>
                  </div>
               </div>
            }
        </div>
    </div>
</dialog>

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback<(double Lat, double Lng, string FormattedAddress, string Name)> OnSuggestionSelected { get; set; }

    private string _searchText = string.Empty;
    private System.Timers.Timer _debounceTimer = new System.Timers.Timer(400);
    private List<(double Lat, double Lng, string FormattedAddress, string Name)> _suggestions = new();
    private bool _showSuggestions = false;
    private bool _isSearchingSuggestions = false;

    private ElementReference _mapDialog;
    private bool _isLoadingMap = false;
    private DotNetObjectReference<LocationSearchAutocomplete>? _dotNetRef;
    private IJSObjectReference? _mapModule;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        _debounceTimer.Elapsed += OnDebounceTimerElapsed;
        _debounceTimer.AutoReset = false;
        _searchText = Value;
    }

    protected override void OnParametersSet()
    {
        if (Value != _searchText && !_showSuggestions)
        {
            _searchText = Value;
        }
    }

    private Task TriggerSearch()
    {
        ValueChanged.InvokeAsync(_searchText);

        _debounceTimer.Stop();
        _isSearchingSuggestions = true;
        _showSuggestions = true;
        _debounceTimer.Start();

        return Task.CompletedTask;
    }

    private async void OnDebounceTimerElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            await InvokeAsync(() =>
            {
                _suggestions.Clear();
                _isSearchingSuggestions = false;
                StateHasChanged();
            });
            return;
        }

        var results = await GeocodingService.GetSuggestionsAsync(_searchText);

        await InvokeAsync(() =>
        {
            _suggestions = results ?? new();
            _activeIndex = -1;
            _isSearchingSuggestions = false;
            StateHasChanged();
        });
    }

    private int _activeIndex = -1;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (!_showSuggestions || _suggestions.Count == 0) return;

        if (e.Key == "ArrowDown")
        {
            _activeIndex = (_activeIndex + 1) % _suggestions.Count;
        }
        else if (e.Key == "ArrowUp")
        {
            _activeIndex = _activeIndex <= 0 ? _suggestions.Count - 1 : _activeIndex - 1;
        }
        else if (e.Key == "Enter" && _activeIndex >= 0 && _activeIndex < _suggestions.Count)
        {
            await SelectSuggestion(_suggestions[_activeIndex]);
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "Escape")
        {
            _showSuggestions = false;
        }
    }

    private async Task SelectSuggestion((double Lat, double Lng, string FormattedAddress, string Name) suggestion)
    {
        _searchText = suggestion.Name;
        _showSuggestions = false;
        await ValueChanged.InvokeAsync(_searchText);
        await OnSuggestionSelected.InvokeAsync(suggestion);
    }

    private async Task OpenMapModal()
    {
        _isLoadingMap = true;
        
        try
        {
            if (_mapModule == null)
            {
                _mapModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/googleMap.js?v=" + DateTime.Now.Ticks);
            }
            
            await _mapModule.InvokeVoidAsync("showDialog", _mapDialog);
            StateHasChanged();
            
            var allLocations = await GeocodingService.GetAllLocationsAsync();
            
            // Map the internal class to an anonymous object that JS can parse
            var jsLocations = allLocations.Select(l => new {
                latitude = l.Latitude,
                longitude = l.Longitude,
                location_name = l.LocationName,
                location_id = l.LocationId
            }).ToList();

            var apiKey = Config.GetValue<string>("GoogleMaps:ApiKey");
            await _mapModule.InvokeVoidAsync("showLocationPickerMap", "picker-map-container", jsLocations, _dotNetRef, apiKey);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to load map: {ex.Message}");
        }
        finally
        {
            _isLoadingMap = false;
            StateHasChanged();
        }
    }

    private async Task CloseMapModal()
    {
        if (_mapModule != null)
        {
            await _mapModule.InvokeVoidAsync("closeDialog", _mapDialog);
        }
    }

    [JSInvokable]
    public async Task OnLocationSelectedFromMap(double lat, double lng, string formattedAddress, string name)
    {
        await CloseMapModal();
        await SelectSuggestion((lat, lng, formattedAddress, name));
    }

    public void Dispose()
    {
        if (_debounceTimer != null)
        {
            _debounceTimer.Elapsed -= OnDebounceTimerElapsed;
            _debounceTimer.Dispose();
        }
        _dotNetRef?.Dispose();
    }

    public async ValueTask DisposeAsync()
    {
        if (_mapModule != null)
        {
            try
            {
                await _mapModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}
