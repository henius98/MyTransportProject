@using MyTransportAppWASM.Models
@using MyTransportAppWASM.Services.Interfaces
@inject MyTransportAppWASM.Services.LanguageService Language
@inject IWeatherPlannerService WeatherPlannerService

<div class="card h-100">
    <div
        class="d-flex align-items-center justify-content-between mb-3 border-bottom border-secondary border-opacity-10 pb-3">
        <div>
            <h3 class="m-0 fw-semibold" style="font-size: 1.15rem; letter-spacing: -0.01em;">@(Options.Name ?? "MetMalaysia")</h3>
                <div class="text-dim mt-1" style="font-size: 0.75rem;">
                    <i class="bi bi-box-arrow-up-right me-1"></i>@(Options.Source ?? "data.gov.my")
                </div>
            </div>
            <span
                class="badge @MyTransportAppWASM.Utils.WeatherUIHelper.GetStatusClass(Provider?.Status ?? "Loading")">@(Provider?.Status ?? "Loading")</span>
            </div>

            @if (isLoading)
            {
                <div class="d-flex justify-content-center p-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (Provider?.Periods != null)
            {
                var groupedPeriods = Provider.Periods.GroupBy(p => p.Time.ToLocalTime().Date);
                <div class="d-flex flex-column gap-3">
                    @foreach (var group in groupedPeriods)
                    {
                        <div class="card shadow-sm border-secondary border-opacity-25"
                             style="overflow: hidden; background: var(--bs-body-bg);">
                            <div
                                class="card-header bg-secondary bg-opacity-10 py-2 px-3 fw-semibold border-bottom border-secondary border-opacity-10 d-flex align-items-center">
                                <i class="bi bi-calendar-day me-2 text-primary"></i>
                                @group.Key.ToString("dddd, dd MMM yyyy")
                            </div>
                            <div class="card-body p-0">
                                @foreach (var slice in group)
                                {
                                    bool isLast = ReferenceEquals(slice, group.Last());
                                    <div
                                        class="d-flex align-items-center p-3 @(isLast ? "" : "border-bottom border-secondary border-opacity-10")">
                                        <div class="me-4 fs-1" style="min-width: 3rem; text-align: center;">
                                            <i class="@slice.Icon"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-start align-items-center mb-1">
                                                @if (slice.Label != "Baseline" && slice.Label != "Outlook" &&
                                    !string.IsNullOrWhiteSpace(slice.Label))
                                                {
                                                    <span class="badge bg-secondary bg-opacity-25 text-body me-2"
                                                          style="font-weight: 500;">@(Language[slice.Label])</span>
                                                }
                                            </div>

                                            <div class="fw-medium mb-1 fs-5" style="letter-spacing: -0.01em;">@(Language[slice.Summary ?? "N/A"])</div>

                                                <div class="d-flex flex-wrap gap-3 text-dim fw-medium" style="font-size: 0.85rem;">
                                                    @if (slice.MinTemperatureC.HasValue && slice.MaxTemperatureC.HasValue)
                                                    {
                                                        <span class="text-danger"><i
                                                            class="bi bi-thermometer-half me-1"></i>@($"{slice.MinTemperatureC:0.#}°C - {slice.MaxTemperatureC:0.#}°C")</span>
                                                    }
                                                    else if (slice.TemperatureC.HasValue)
                                                    {
                                                        <span class="text-danger"><i
                                                            class="bi bi-thermometer-half me-1"></i>@($"{slice.TemperatureC:0.#}°C")</span>
                                                    }
                                                        @if (!string.IsNullOrWhiteSpace(slice.Wind))
                                                        {
                                                            <span><i class="bi bi-wind me-1"></i>@slice.Wind</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

@code {
    [Parameter, EditorRequired]
    public required WeatherProviderOptions Options { get; set; }

    [Parameter, EditorRequired]
    public required WeatherQuery Query { get; set; }

    [Parameter]
    public string Label { get; set; } = "Baseline";

    [Parameter]
    public bool FetchOutlook { get; set; } = false;

    private WeatherProviderResult? Provider;
    private bool isLoading = true;
    private string? lastUrl;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (Options.Enabled && !string.IsNullOrWhiteSpace(Options.BaseUrl))
            {
                string endpointPath = string.Empty;
                if (FetchOutlook && Options.Endpoints != null && Options.Endpoints.TryGetValue("Outlook", out string? outlookPath))
                {
                    endpointPath = outlookPath;
                }
                else if (Options.Endpoints != null && Options.Endpoints.TryGetValue("Baseline", out string? baselinePath))
                {
                    endpointPath = baselinePath;
                }

                string fullUrl = Options.BaseUrl + endpointPath;
                Uri uri = BuildUri(fullUrl, Query);
                
                if (lastUrl == uri.AbsoluteUri)
                    return; // Prevent duplicate fetches on parent re-render
                
                lastUrl = uri.AbsoluteUri;
                isLoading = true;

                Provider = await WeatherPlannerService.FetchProviderDataAsync(Options, uri, Label);

                // If fetching baseline, just grab the closest time
                if (!FetchOutlook && Provider.Periods.Count > 1)
                {
                    var now = DateTimeOffset.UtcNow;
                    var closest = Provider.Periods.OrderBy(p => Math.Abs((p.Time - now).Ticks)).FirstOrDefault();
                    if (closest != null)
                        Provider = Provider with { Periods = new List<WeatherTimeSlice> { closest } };
                }
                else if (FetchOutlook && Provider.Periods.Count > 0)
                {
                    var now = DateTimeOffset.UtcNow;
                    var sortedPeriods = Provider.Periods.Where(p => p.Time.Date >= now.Date).OrderBy(p => p.Time).Take(14).ToList();
                    Provider = Provider with { Periods = sortedPeriods };
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private Uri BuildUri(string template, WeatherQuery query)
    {
        var formatted = template;

        if (formatted.Contains("{location_id}", StringComparison.OrdinalIgnoreCase))
        {
            string locId = !string.IsNullOrWhiteSpace(query.LocationId) ? query.LocationId : "Ds058";
            formatted = formatted.Replace("{location_id}", Uri.EscapeDataString(locId), StringComparison.OrdinalIgnoreCase);
        }

        if (formatted.Contains("{date_start}", StringComparison.OrdinalIgnoreCase) || formatted.Contains("{date_end}",
StringComparison.OrdinalIgnoreCase))
        {
            var start = query.Departure ?? DateTimeOffset.UtcNow;
            var end = query.Return ?? start.AddDays(7);
            formatted = formatted.Replace("{date_start}", start.ToString("yyyy-MM-dd"), StringComparison.OrdinalIgnoreCase);
            formatted = formatted.Replace("{date_end}", end.ToString("yyyy-MM-dd"), StringComparison.OrdinalIgnoreCase);
        }

        if (!string.IsNullOrWhiteSpace(Options.ApiKey))
            formatted = formatted.Replace("{key}", Options.ApiKey, StringComparison.OrdinalIgnoreCase).Replace("{apiKey}",
Options.ApiKey, StringComparison.OrdinalIgnoreCase);

        return new Uri(formatted, UriKind.Absolute);
    }
}
