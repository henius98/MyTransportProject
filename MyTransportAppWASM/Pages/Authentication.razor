@page "/authentication/{action}"
@layout MainLayout
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="auth-popup-container" @onclick="CloseWindow">
    <div class="auth-modal" @onclick:stopPropagation="true">
        <button type="button" class="auth-close-btn" @onclick="CloseWindow" aria-label="Close">&times;</button>
        
        <RemoteAuthenticatorView Action="@Action" OnLogInSucceeded="HandleSuccess" OnLogOutSucceeded="HandleSuccess">
            <LoggingIn>
                <div class="auth-spinner"></div>
                <h2 class="fw-bold">Signing You In</h2>
                <p>Please wait while we connect to Google...</p>
            </LoggingIn>
            <LogInFailed>
                <div class="welcome-icon">❌</div>
                <h2 class="fw-bold">Sign-in Failed</h2>
                <p class="text-muted">@context</p>
                <button class="standard-button standard-button-primary mt-2 w-100" @onclick="CloseWindow">Try Again</button>
            </LogInFailed>
            <LogOut>
                <div class="auth-spinner"></div>
                <h2 class="fw-bold">Logging Out</h2>
                <p>We're signing you out of your session...</p>
            </LogOut>
            <LogOutFailed>
                <div class="welcome-icon">❌</div>
                <h2 class="fw-bold">Logout Failed</h2>
                <p class="text-muted">@context</p>
                <button class="standard-button standard-button-primary mt-2 w-100" @onclick="CloseWindow">Close</button>
            </LogOutFailed>
            <CompletingLogOut>
                <div class="auth-spinner"></div>
                <h2 class="fw-bold">Finalizing</h2>
                <p>Almost done...</p>
            </CompletingLogOut>
            <LogOutSucceeded>
                <div class="welcome-icon">✅</div>
                <h2 class="fw-bold">Logged Out</h2>
                <p>You have been successfully logged out.</p>
                <div class="app-stats mb-3">
                    <div class="stat-item">
                        <span class="stat-value">Success</span>
                        <span class="stat-label">Status</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <span class="stat-value">6s</span>
                        <span class="stat-label">Auto-Close</span>
                    </div>
                </div>
                <button class="standard-button standard-button-primary w-100" @onclick="CloseWindow">Done</button>
            </LogOutSucceeded>
        </RemoteAuthenticatorView>
    </div>
</div>

@code {
    [Parameter] public string? Action { get; set; }

    private void CloseWindow()
    {
        Navigation.NavigateTo("/");
    }

    private void HandleSuccess()
    {
        // Start 6 second auto-close timer to return to homepage
        _ = Task.Run(async () => {
            await Task.Delay(6000);
            Navigation.NavigateTo("/");
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Internal logic for RemoteAuthenticatorView
    }
}
