@page "/weather"
@using System.Linq
@using MyTransportAppWASM.Models.Weather
@using MyTransportAppWASM.Services.Interfaces
@using MyTransportAppWASM.Services
@using MyTransportAppWASM.Pages.Components
@inject IWeatherPlannerService WeatherPlannerService
@inject IGeocodingService GeocodingService
@inject ILocationService LocationService
@implements IDisposable

<PageTitle>Trip Weather Planner</PageTitle>

<h1 class="section-title">Trip Weather Planner 
    <button class="btn btn-link p-0 ms-2" @onclick="ToggleHelp" title="How this works" style="vertical-align: middle;">
        <span style="font-size: 1.8rem;">❓</span>
    </button>
</h1>
<p class="section-subtitle">
  Get an at-a-glance plan that blends live forecasts and outlooks based on your location.
</p>

<div class="planner-grid">
  <div class="standard-card">
    <h3 class="mb-3">Location</h3>
    <div class="mb-3">
      <label class="standard-label">Search by Place Name</label>
      <div class="search-container">
        <input class="standard-input" @bind="query.PlaceName" @bind:event="oninput" @onkeyup="HandleKeyUp" placeholder="e.g., Kuala Lumpur Sentral" />
        <button class="standard-button standard-button-primary px-3" @onclick="SearchLocation" disabled="@isGeocoding">
          @(isGeocoding ? "..." : "🔍")
        </button>
      </div>
    </div>
    <div class="row g-2">
      <div class="col">
        <label class="standard-label">Latitude</label>
        <InputNumber TValue="double" @bind-Value="query.Latitude" class="standard-input" Step="0.0001" />
      </div>
      <div class="col">
        <label class="standard-label">Longitude</label>
        <InputNumber TValue="double" @bind-Value="query.Longitude" class="standard-input" Step="0.0001" />
      </div>
    </div>
    <div class="row g-2 mt-2">
      <div class="col">
        <label class="standard-label">Depart</label>
        <InputDate TValue="DateTime?" @bind-Value="departureDate" class="standard-input" />
      </div>
      <div class="col">
        <label class="standard-label">Return</label>
        <InputDate TValue="DateTime?" @bind-Value="returnDate" class="standard-input" />
      </div>
    </div>
    <div class="mt-4 d-flex gap-2">
      <button class="standard-button standard-button-primary" @onclick="LoadPlanAsync" disabled="@isLoading">
        @(isLoading ? "Loading..." : "Get forecast")
      </button>
      <button class="standard-button bg-light text-dark" @onclick="ResetToLocalLocation" disabled="@isLoading">Use My Location</button>
    </div>
  </div>
</div>

@if (showHelp)
{
    <div class="auth-popup-container" style="position: fixed; z-index: 2000; top: 0; left: 0; width: 100%; height: 100%;" @onclick="ToggleHelp">
        <div class="auth-modal" @onclick:stopPropagation="true">
            <button type="button" class="auth-close-btn" @onclick="ToggleHelp">&times;</button>
            <div class="welcome-icon">💡</div>
            <h2 class="fw-bold">How this works</h2>
            <p class="text-start">Plan your trip with precision using our multi-source weather engine:</p>
            <ul class="text-start mb-3" style="list-style: none; padding-left: 0;">
                <li class="mb-2">📍 <strong>Search:</strong> Type any place name and click 🔍 to update coordinates.</li>
                <li class="mb-2">🌦️ <strong>Baseline:</strong> Real-time forecasts from high-availability providers.</li>
                <li class="mb-2">📅 <strong>Outlooks:</strong> Multi-day weather trends for your return trip.</li>
            </ul>
            <button class="standard-button standard-button-primary w-100" @onclick="ToggleHelp">Got it!</button>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
  <div class="alert alert-danger" role="alert">@error</div>
}

@if (isLoading)
{
    <div class="planner-grid">
        @for (int i = 0; i < 3; i++)
        {
            <div class="standard-card animate-pulse" style="min-height: 200px; opacity: 0.6;">
                <div class="d-flex justify-content-between mb-4">
                    <div style="width: 120px; height: 24px; background: var(--border-color); border-radius: 4px;"></div>
                    <div style="width: 60px; height: 24px; background: var(--border-color); border-radius: 4px;"></div>
                </div>
                <div class="mb-3" style="width: 100%; height: 16px; background: var(--border-color); border-radius: 4px;"></div>
                <div class="mb-2" style="width: 80%; height: 16px; background: var(--border-color); border-radius: 4px;"></div>
                <div style="width: 90%; height: 16px; background: var(--border-color); border-radius: 4px;"></div>
            </div>
        }
    </div>
}
else if (plan is null)
{
  <p class="text-dim">Search for a location or adjust coordinates, then click "Get forecast".</p>
}
else if (plan is not null)
{
  <div class="standard-card mb-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between">
      <div>
        <strong>Requested:</strong> @DisplayLocation(plan.Query)
        @if (plan.Query.Departure.HasValue || plan.Query.Return.HasValue)
        {
          <span class="ms-2 text-dim">
            @DisplayDateRange(plan.Query.Departure, plan.Query.Return)
          </span>
        }
      </div>
      <div>
        @if (plan.Notes != null)
        {
          @foreach (string note in plan.Notes)
          {
            <span class="standard-chip">@note</span>
          }
        }
      </div>
    </div>
  </div>

  <div class="planner-grid">
    <WeatherCard Provider="plan.Baseline" />
    <WeatherCard Provider="plan.Radar" />
    @foreach (var outlook in plan.Outlooks)
    {
      <WeatherCard Provider="outlook" />
    }
  </div>
}

@code {
  private WeatherQuery query = new()
  {
    PlaceName = "Kuala Lumpur Sentral",
    Latitude = 3.1347,
    Longitude = 101.6869
  };

  private DateTime? departureDate = DateTime.Today;
  private DateTime? returnDate = DateTime.Today.AddDays(3);
  private WeatherPlanResult? plan;
  private string? error;
  private bool isLoading;
  private bool isGeocoding;
  private bool showHelp;
  private CancellationTokenSource cts = new();

  private void ToggleHelp() => showHelp = !showHelp;

  public void Dispose()
  {
      cts.Cancel();
      cts.Dispose();
  }

  protected override async Task OnInitializedAsync()
  {
    await Task.Yield();
    
    // Try to get current location automatically
    try
    {
        var pos = await LocationService.GetCurrentLocationAsync();
        if (cts.IsCancellationRequested) return;

        if (pos != null)
        {
            query.Latitude = pos.Latitude;
            query.Longitude = pos.Longitude;
            query.PlaceName = "Current Location";
        }

        await LoadPlanAsync();
    }
    catch (Exception ex) when (ex is TaskCanceledException || ex is OperationCanceledException)
    {
        // Suppress
    }
  }

  private async Task SearchLocation()
  {
      if (string.IsNullOrWhiteSpace(query.PlaceName)) return;

      isGeocoding = true;
      StateHasChanged();

      try 
      {
          var result = await GeocodingService.GeocodeAsync(query.PlaceName);
          if (result.HasValue)
          {
              query.Latitude = result.Value.Lat;
              query.Longitude = result.Value.Lng;
              query.PlaceName = result.Value.FormattedAddress;
          }
          else
          {
              error = "Could not find that location.";
          }
      }
      catch (Exception ex)
      {
          error = "Geocoding error.";
          Console.Error.WriteLine(ex);
      }
      finally
      {
          isGeocoding = false;
          StateHasChanged();
      }
  }

  private async Task HandleKeyUp(KeyboardEventArgs e)
  {
      if (e.Key == "Enter") await SearchLocation();
  }

  private async Task LoadPlanAsync()
  {
    if (isLoading) return;

    isLoading = true;
    error = null;
    StateHasChanged();

    try
    {
      query.Departure = departureDate.HasValue ? new DateTimeOffset(departureDate.Value) : null;
      query.Return = returnDate.HasValue ? new DateTimeOffset(returnDate.Value) : null;
      plan = await WeatherPlannerService.GetWeatherPlanAsync(query, cts.Token);
    }
    catch (Exception ex)
    {
      error = "Unable to load weather.";
      Console.Error.WriteLine(ex);
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private async Task ResetToLocalLocation()
  {
    var pos = await LocationService.GetCurrentLocationAsync();
    if (pos != null)
    {
        query.Latitude = pos.Latitude;
        query.Longitude = pos.Longitude;
        query.PlaceName = "Current Location";
        await LoadPlanAsync();
    }
  }

  private static string DisplayLocation(WeatherQuery value)
  {
    string location = string.IsNullOrWhiteSpace(value.PlaceName) ? "Custom location" : value.PlaceName;
    return $"{location} ({value.Latitude:F3}, {value.Longitude:F3})";
  }

  private static string DisplayDateRange(DateTimeOffset? start, DateTimeOffset? end)
  {
    string startText = start.HasValue ? start.Value.ToString("dd MMM") : "?";
    string endText = end.HasValue ? end.Value.ToString("dd MMM") : "?";
    return (startText == "?" && endText == "?") ? string.Empty : $"{startText} → {endText}";
  }
}
