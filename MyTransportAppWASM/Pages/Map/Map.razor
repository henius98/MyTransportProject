@page "/map"
@using MyTransportAppWASM.Services.Interfaces
@using MyTransportAppWASM.Models
@using MyTransportAppWASM.Services

<PageTitle>Live Bus Map - MyTransportApp</PageTitle>

<div id="map-container" class="@MapContainerClass">
    <div id="map"></div>

    <div class="@MapOverlayClass glass-panel">
        <div class="overlay-header d-flex justify-content-between align-items-center w-100" 
             @onclick="ToggleCollapse" 
             @onkeydown="@(e => { if (e.Key == "Enter" || e.Key == " ") ToggleCollapse(); })"
             role="button" tabindex="0" 
             aria-expanded="@((!isCollapsed).ToString().ToLower())" aria-label="Toggle tracker panel">
            <div class="d-flex align-items-center gap-2">
                <span class="collapsed-icon" aria-hidden="true">📍</span>
                @if (!isCollapsed)
                {
                    <h2 class="m-0 fs-5">Rapid Bus Tracker</h2>
                }
            </div>
        </div>

        <div class="overlay-body" style="@(isCollapsed ? "visibility: hidden;" : "")">
                <div class="control-group mb-3">
                    <label class="form-label" for="origin-input">Origin</label>
                    <div id="origin-input" class="form-input autocomplete-container"></div>
                </div>

                <div class="control-group mb-3">
                    <label class="form-label" for="destination-input">Destination</label>
                    <div id="destination-input" class="form-input autocomplete-container"></div>
                </div>

                <div class="control-group mb-3">
                    <label class="form-label" for="travel-mode-select">Travel Mode</label>
                    <select id="travel-mode-select" @bind="mode" class="form-input">
                        <option value="TRANSIT">🚌 Transit</option>
                        <option value="WALKING">🚶 Walking</option>
                        <option value="DRIVING">🚗 Driving</option>
                        <option value="BICYCLING">🚲 Bicycling</option>
                    </select>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button @onclick="ShowRoute" class="btn btn--primary flex-grow-1 shadow-sm">
                        🗺️ Route
                    </button>
                    <button @onclick="ClearRoute" class="btn btn--secondary btn--sm flex-grow-1">
                        🗑️ Clear
                    </button>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <button @onclick="() => RequestManualLocationUpdate()"
                            class="btn btn--secondary btn--sm flex-grow-1">
                        🎯 My Location
                    </button>
                    <button @onclick="RefreshBusPosition" class="btn btn--secondary btn--sm flex-grow-1">
                        🔄 Update Buses
                    </button>
                </div>

                <div class="tracker-status">
                    <span class="pulse-dot"></span>
                    <span>@(string.IsNullOrEmpty(locationStatus) ? "Ready" : locationStatus)</span>
                </div>
            </div>
    </div>
</div>

