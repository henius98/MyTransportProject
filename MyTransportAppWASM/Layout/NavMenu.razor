@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using MyTransportAppWASM.Services
@inject NavigationManager Navigation
@inject ThemeService Theme
@inject IJSRuntime JS
@inject LanguageService Language

@implements IDisposable

<div class="@ContainerClass">
    <div class="top-row ps-3 navbar" data-bs-theme="dark">
        <div class="container-fluid d-flex justify-content-start align-items-center flex-nowrap">
            <div class="profile me-3 position-relative" @onclick="() => { }" @onclick:stopPropagation="true">
                <button class="btn btn-link p-0 text-white shadow-none" @onclick="ToggleUserMenu" aria-label="User Profile" title="User Profile">
                    <AuthorizeView>
                        <Authorized>
                            @if (!string.IsNullOrEmpty(context.User?.FindFirst("picture")?.Value))
                            {
                                <img src="@context.User?.FindFirst("picture")?.Value" class="avatar avatar--sm"
                                     alt="Profile" />
                            }
                            else
                            {
                                <span class="bi bi-person-circle-nav-menu" aria-hidden="true"></span>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <span class="bi bi-person-circle-nav-menu" aria-hidden="true"></span>
                        </NotAuthorized>
                    </AuthorizeView>
                </button>

                @if (showUserMenu)
                {
                    <div class="dropdown__overlay" @onclick="ToggleUserMenu"></div>
                    <div class="user-menu-dropdown p-3 shadow-lg" style="min-width: 250px;">
                        <AuthorizeView>
                            <Authorized>
                                <div class="d-flex align-items-center mb-3">
                                    @if (!string.IsNullOrEmpty(context.User?.FindFirst("picture")?.Value))
                                    {
                                        <img src="@context.User?.FindFirst("picture")?.Value" class="avatar avatar--lg me-3"
                                             alt="Profile" />
                                    }
                                    <div class="text-truncate">
                                        <div class="profile__name fw-bold">@(context.User?.Identity?.Name ?? "User")</div>
                                        <div class="text-muted text--xs text-truncate" style="font-size: 0.75rem;">
                                            @(context.User?.FindFirst("email")?.Value ?? "")</div>
                                        </div>
                                    </div>
                                    <small class="text-muted d-block mb-2">Signed in with Google</small>
                                </Authorized>
                            </AuthorizeView>

                            <hr class="my-2 border-secondary" />

                            <div class="mb-3 mt-3">
                                <small class="text-muted d-block mb-2 text-uppercase"
                                       style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px;">@Language["Preferences"]</small>
                                
                                <div class="switch-group d-flex align-items-center justify-content-between p-2 rounded mb-2">
                                    <div class="d-flex align-items-center">
                                        <span class="bi bi-moon-stars-fill-nav-menu me-2" aria-hidden="true"></span>
                                        <span style="font-size: 0.85rem;">@(Theme.IsDarkMode ? Language["DarkMode"] : Language["LightMode"])</span>
                                    </div>
                                    <div class="form-check form-switch m-0">
                                        <input class="form-check-input switch shadow-none" type="checkbox" role="switch"
                                               aria-label="Toggle Dark Mode"
                                               checked="@Theme.IsDarkMode" @onchange="Theme.ToggleThemeAsync" />
                                    </div>
                                </div>
                                
                                <div class="switch-group d-flex align-items-center justify-content-between p-2 rounded">
                                    <LanguageSwitcher />
                                </div>
                            </div>

                            <hr class="my-2 border-secondary" />

                            <AuthorizeView>
                                <Authorized>
                                    <button class="nav-link btn btn-link text-start w-100" @onclick="BeginLogOut">
                                        <span class="bi bi-box-arrow-right-nav-menu me-2" aria-hidden="true"></span> @Language["LogOut"]
                                    </button>
                                </Authorized>
                                <NotAuthorized>
                                    <button class="nav-link btn btn-link text-start w-100" @onclick="BeginLogin">
                                        <span class="bi bi-box-arrow-in-right-nav-menu me-2" aria-hidden="true"></span> @Language["LogIn"]
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </div>
                    }
                </div>
                <a class="navbar-brand text-truncate" href="">MyTransportApp</a>
            </div>
        </div>

        <input id="nav-toggler" type="checkbox" aria-label="Toggle Navigation Menu" title="Navigation menu" class="navbar-toggler" />

        <div class="nav-scrollable">
            <nav class="nav flex-column" aria-label="Main navigation" @onclick="CollapseNav" @onclick:stopPropagation="true">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                        <span class="nav-text ms-2">@Language["Home"]</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="weather">
                        <span class="bi bi-cloud-sun-fill-nav-menu" aria-hidden="true"></span>
                        <span class="nav-text ms-2">@Language["Weather"]</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="map">
                        <span class="bi bi-geo-alt-fill-nav-menu" aria-hidden="true"></span>
                        <span class="nav-text ms-2">@Language["Map"]</span>
                    </NavLink>
                </div>
            </nav>
        </div>
    </div>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string ContainerClass => $"nav-menu-container {(IsCollapsed ? "collapsed" : "")}".Trim();
    private bool showUserMenu;

    protected override async Task OnInitializedAsync()
    {
        Theme.OnThemeChanged += StateHasChanged;
        Language.OnLanguageChanged += StateHasChanged;
    }

    private void ToggleUserMenu() => showUserMenu = !showUserMenu;

    private async Task BeginLogin()
    {
        await JS.InvokeVoidAsync("appAuth.clearExplicitLogout");
        Navigation.NavigateTo($"authentication/login?returnUrl={Uri.EscapeDataString(Navigation.Uri)}");
    }

    private async Task BeginLogOut()
    {
        // Purge OIDC session state first — Google doesn't support end_session_endpoint
        // for implicit flow, so Blazor's standard logout may not fully clear the session.
        await JS.InvokeVoidAsync("appAuth.noteExplicitLogout");
        await JS.InvokeVoidAsync("appAuth.purgeOidcState");
        Navigation.NavigateToLogout("authentication/logout");
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
        Language.OnLanguageChanged -= StateHasChanged;
    }

    private async Task CollapseNav()
    {
        try
        {
            // Trigger the CSS-only mobile menu to close when a link is clicked
            await JS.InvokeVoidAsync("eval", "var t = document.querySelector('.navbar-toggler'); if(t && t.checked) t.click();");
        }
        catch { }
    }
}
