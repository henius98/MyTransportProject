@using Blazored.LocalStorage
@using MyTransportAppWASM.Services
@inject LanguageService Language
@inject ILocalStorageService LocalStorage

<div class="d-flex align-items-center justify-content-between w-100 p-0 m-0">
    <div class="d-flex align-items-center">
        <span class="bi bi-translate me-2" aria-hidden="true"></span>
        <span style="font-size: 0.85rem;">@CurrentOption.NativeLabel</span>
    </div>

    <div class="btn-group" @onfocusout="OnFocusOut">
        <button class="btn btn-sm btn-link text-muted text-decoration-none dropdown-toggle p-0 shadow-none m-0"
                type="button" aria-expanded="@(_isOpen.ToString().ToLower())" aria-haspopup="menu" aria-label="Select language" 
                style="font-size: 0.85rem;" @onclick="ToggleDropdown">
            @CurrentOption.ShortName
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm @(_isOpen ? "show" : "")" style="position: absolute; right: 0; top: 100%;" role="menu">
            @foreach (var lang in LanguageService.SupportedLanguages)
            {
                <li role="presentation">
                    <button class="dropdown-item" type="button" role="menuitem" @onclick='() => ChangeLanguage(lang.Code)'>
                        @lang.FullName
                    </button>
                </li>
            }
        </ul>
    </div>
</div>

@code {
    private bool _isOpen;

    private LanguageOption CurrentOption => LanguageService.SupportedLanguages.FirstOrDefault(l => l.Code ==
Language.CurrentLanguageName) ?? LanguageService.SupportedLanguages[0];

    protected override async Task OnInitializedAsync()
    {
        var savedLang = await LocalStorage.GetItemAsync<string>("user_language");
        if (!string.IsNullOrEmpty(savedLang) && savedLang != Language.CurrentLanguageName)
        {
            await Language.LoadLanguageAsync(savedLang);
        }
    }

    private void ToggleDropdown()
    {
        _isOpen = !_isOpen;
    }

    private async Task OnFocusOut(FocusEventArgs e)
    {
        // Delay to allow click event to register before closing
        await Task.Delay(150);
        _isOpen = false;
        StateHasChanged();
    }

    private async Task ChangeLanguage(string langCode)
    {
        await Language.LoadLanguageAsync(langCode);
        await LocalStorage.SetItemAsync("user_language", langCode);
        _isOpen = false;
    }
}
