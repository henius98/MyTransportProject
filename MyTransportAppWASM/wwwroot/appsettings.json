{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authorization": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GoogleMaps": {
    "ApiKey": "__GOOGLE_MAPS_API_KEY__"
  },
  "Authentication": {
    "Google": {
      "Authority": "https://accounts.google.com/",
      "ClientId": "__GOOGLE_CLIENT_ID__",
      "PostLogoutRedirectUri": "/",
    "ResponseType": "id_token"
    }
  },
  "WeatherProviders": {
    "MetMalaysia": {
      "Enabled": true,
      "Name": "MetMalaysia (data.gov.my)",
      "Source": "data.gov.my",
      "BaseUrl": "https://api.data.gov.my/weather/forecast/?contains={location_id}@location__location_id&date_start={date_start}@date&date_end={date_end}@date&exclude=summary_forecast,summary_when"
    },
    "SingaporeNEA": {
      "Enabled": true,
      "Name": "Singapore NEA",
      "Source": "data.gov.sg",
      "BaseUrl": "https://api-open.data.gov.sg/v2/real-time/api/",
      "Endpoints": {
        "Baseline": "two-hr-forecast",
        "Outlook": "four-day-outlook"
      }
    },
    "OpenMeteo": {
      "Enabled": true,
      "Name": "Open-Meteo",
      "Source": "open-meteo.com",
      "BaseUrl": "https://api.open-meteo.com/v1/forecast",
      "Endpoints": {
        "Baseline": "?latitude={lat}&longitude={lon}&current_weather=true&hourly=temperature_2m,precipitation_probability,precipitation,weather_code&forecast_hours={forecast_hours}&timezone=UTC",
        "Outlook": "?latitude={lat}&longitude={lon}&daily=temperature_2m_max,precipitation_probability_max,weather_code&forecast_days={forecast_days}&timezone=UTC"
      }
    }
  },
