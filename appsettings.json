{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GoogleMaps": {
    "ApiKey": ""
  },
  "Authentication": {
    "Google": {
      "Authority": "https://accounts.google.com/",
      "ClientId": "",
      "PostLogoutRedirectUri": "/",
    "ResponseType": "id_token"
    }
  },
  "WeatherProviders": {
    "MetMalaysia": {
      "Enabled": true,
      "Name": "Open-Meteo (CORS)",
      "Source": "Open-Meteo.com",
      "Endpoint": "https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current_weather=true&hourly=temperature_2m,precipitation_probability,precipitation&timezone=auto",
      "ApiKey": ""
    },
    "SingaporeNEA": {
      "Enabled": true,
      "Name": "Singapore NEA",
      "Source": "data.gov.sg",
      "Endpoint": "https://api-open.data.gov.sg/v2/real-time/api/",
      "Suffixes": {
        "Baseline": "two-hr-forecast",
        "Outlook": "four-day-outlook"
      }
    },
    "Weatherbit": {
      "Enabled": true,
      "Name": "Weatherbit",
      "Source": "weatherbit.io",
      "Endpoint": "https://api.weatherbit.io/v2.0/",
      "ApiKey": "",
      "Suffixes": {
        "Baseline": "current?lat={lat}&lon={lon}&key={apiKey}",
        "Outlook": "forecast/daily?lat={lat}&lon={lon}&key={apiKey}"
      }
    },
    "Radar": {
      "Enabled": false,
      "Endpoint": "https://api.met.gov.my/v2/weather/radar/nowcast?lat={lat}&lon={lon}"
    },
    "Outlooks": [
      {
        "Name": "Open-Meteo Daily",
        "Source": "open-meteo.com",
        "Enabled": true,
        "Endpoint": "https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&daily=temperature_2m_max,precipitation_probability_max&timezone=auto"
      }
    ]
  },
